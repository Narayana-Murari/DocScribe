# Copy to .env and fill in only what you have. Claude needs NO key —
# it runs on your Claude Code login (Pro subscription).

# Optional: pin the Claude model used by the Agent SDK (e.g. "sonnet" for speed)
# CLAUDE_MODEL=sonnet

# OpenAI
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o

# Gemini (OpenAI-compatible endpoint)
# GEMINI_API_KEY=...
# GEMINI_MODEL=gemini-2.5-flash

# Kimi / Moonshot
# KIMI_API_KEY=...
# KIMI_MODEL=kimi-k2-turbo-preview

# NVIDIA NIM — free models at build.nvidia.com (key starts with nvapi-)
# One key powers both NVIDIA providers in the dropdown (GLM-5.2 and MiniMax-M3).
# NVIDIA_API_KEY=nvapi-...
# NVIDIA_GLM_MODEL=z-ai/glm-5.2
# NVIDIA_MINIMAX_MODEL=minimaxai/minimax-m3

# PORT=3001
